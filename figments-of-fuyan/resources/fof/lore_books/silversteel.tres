[resource]
script = ExtResource("3_wi33n")
category = 14
text = "Silversteel is a highly resistant but lightweight material used primarily by the Stone Empire to arm their soldiers. It's origins are not confirmed, although it is widely believed they are found in the caves of Rutof. Stone Empire's countries are provided a certain amount of silversteel to do with as they please, an enticing benefit that converted Janaite to become a vassal state 260 years ago. Varoma use them to create silversteel shields for the regular soldiers and full armor for officers or higher. It is illegal to trade overseas without government permission, this rule is strictly enforced as the Stone Empire fears it will lose it's military advantage if other nations have enough to arm their armies."
id = 49
name = "Silversteel"
gdscript = ExtResource("1_6fs7u")
saved_data = ExtResource("2_roi1u")
