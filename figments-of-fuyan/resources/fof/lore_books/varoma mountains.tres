[resource]
script = ExtResource("3_i7jfc")
category = 4
text = "The Varoma Mountains have three traversable paths, Boulder's way leads to the aptly named Boulder, a massive darkstone Varoma fortress resembling a boulder. This path is primarily controlled by the Ka'luta as it leads into their territority. The Old Road now lays abandoned, as any traveller is attacked by the supersized critters that resurface from the caves or the snowfuries found on the mountain peaks, it is used only by the most desperate adventurers. Finally, the Stone Road, travells through Manok, Holy Shreev and Rutof into the mainland of the Stone Empire. Ka'luta often raid the section that is within their territory and so the Bulwark's army, the Border Brothers extend their protection to the Stone Road's pathway, often sending patrols to protect delievery of important good from the Stoneland or Manokian merchants."
id = 76
name = "Varoma Mountains"
gdscript = ExtResource("1_77wcc")
saved_data = ExtResource("2_beypj")
