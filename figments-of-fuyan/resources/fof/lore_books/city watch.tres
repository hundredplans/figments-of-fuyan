[resource]
script = ExtResource("3_7fhc7")
category = 4
text = "The City Watch can be found in each town or city of the Varoma, regardless of the city's size a minimum of 20 knights serve in the watch per city. Each Captain of the City Watch writes directly to the Blade when problems arise and the message is carried to Lastock as well as other cities with their own watches, due to this Varoma's response time to reinforce a weakened city after a raid is admirable. Knights of other city watches make their way to the attacked city and the cities they left are fortified for a few weeks by other City Watch knights or the Valor's Silver Army if need be."
id = 71
name = "City Watch"
gdscript = ExtResource("1_hfb4o")
saved_data = ExtResource("2_8mjtf")
