[resource]
script = ExtResource("3_2t4ma")
category = 4
text = "The Stone Empire has a deep hatred of spellcasting that the Varoma were taught. Despite this, some magical artifacts are secretly used by the Varoma. The Silver Army marches tremendous distances when the Four Towers or the Boulder is attacked and to keep up a steady pace Horns of Power are used. They rejuvenate the Knights and inspire loyalty to the land of Varoma. Banners of Power are similary used but in battles, any man who sees such a Banner loses respect for his life and instead fights for the good of Varoma. Most of the Knights of Varoma are unaware these are magical artifacts however, as this information is kept hidden by the Arbiter. Hate of all magic is used as a rallying force against the Ka'luta, it would do no good to reveal some magical artifacts are utilized by the Varoma."
id = 70
name = "Artifacts of Power"
gdscript = ExtResource("1_ekfug")
saved_data = ExtResource("2_luvs6")
