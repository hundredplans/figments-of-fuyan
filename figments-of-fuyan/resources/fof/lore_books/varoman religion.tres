[resource]
script = ExtResource("3_gpymr")
category = 4
text = "After Peace's End, an unexpected occurence happened. The families who came from the Stoneland, which has no official religion and allows the practice of any, were converted to the beliefs of the shepherds of Varoma. Fuyanism is the worship of the First Man who is said to have created the world, Elvus. The shepherds try to emulate the First Man's values of kindness, stability and honor. The Stonemen adapted this religion to fit their values, believing their conquest brought stability and kindness to the previous people of Varoma. The Stonemen have also spread their beliefs in honor, glory and triumph to the Varoman people. This combination of ideals has resulted in a culture where many young boys aspire to be knights."
id = 74
name = "Varoman Religion"
gdscript = ExtResource("1_pia6r")
saved_data = ExtResource("2_6ooaq")
