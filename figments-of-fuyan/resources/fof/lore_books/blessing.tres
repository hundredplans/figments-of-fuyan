[resource]
script = ExtResource("3_upw1j")
category = 6
text = "The Blessing of Creation was given to the Disciples of the First Man. The blessing is then inherited by blood, or soul, with the child having a natural predisposition to whatever element their parent's were strongest in at the time of conception. It should be noted anyone possessing the blessing can use any of the elements. It's common for the child of a strong mage to discover their innate abilities young, even without knowing the existence of Creation magic. However this strength only shows what kind of potential you can reach, many with great mages as parents don't ever learn a basic fireball and others with magicless parents become great mages. 

Over the three millenia since the First Man's departure, the Blessing has spread to far reaches of the world, there are many of those who have the ability and never learn of it."
id = 110
name = "Blessing"
gdscript = ExtResource("1_e86lh")
saved_data = ExtResource("2_momi6")
