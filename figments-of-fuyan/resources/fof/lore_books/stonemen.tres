[resource]
script = ExtResource("3_0fnq0")
category = 14
text = "The Stonemen is the name for the people of the Stoneland, the mainland of the Stone Empire. They are often tall and bulky with dark hair and copper eyes. Their skin is often tanned but naturally light. Stonemen are very rarely born with magical talent, those who are unlucky enough to be born with it are advised by their loved ones to keep it hidden, or if their families beliefs run deep, exposed to the Order of the Stone and never seen again. Stonemen live to fight, they believe in the the motto of the Stoneland \"Honor, Glory & Triumph\", these are seen as the most important values a man can pursue."
id = 51
name = "Stonemen"
gdscript = ExtResource("1_i0k8s")
