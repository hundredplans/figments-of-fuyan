script = ExtResource("3_73n6k")
category = 10
text = "2300ish years ago, ancient village on the coastline of Bauland that made artifacts, Nolak did not like it as he thought it was a dangerous art, so they had to throw their artifacts. 
some didnt like it so they set out to find the artifacts, ended up settling on East Pustan, where they still live to this day albeit quite differently, making artifacts and searching for them.
supposedly Gildred is from the Ancient Nolkain village"
id = 41
name = "Nolkain"
