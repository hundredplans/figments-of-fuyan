[sub_resource type="Resource" id="Resource_cnfqv"]
script = ExtResource("1_8ut2b")
title = "StartPage"
description = "An army border recruiter with a menacing shield and helmet offers to train one of your soldiers. But he will need a soldier of equal strength to help man the border."
options = Array[ExtResource("3_d2jt1")]([SubResource("Resource_4sqey"), SubResource("Resource_onmwi")])

[sub_resource type="Resource" id="Resource_k6iy1"]
script = ExtResource("1_8ut2b")
title = "AcceptPage"
description = "You accept the border recruiter's request and wait a few days at his camp as he trains your unit. You can see his attack getting sharper and his defense becoming stronger. As you bid farewell you can see the unit you left behind talking merrily with the veterans, it seems he will fit in here."
options = Array[ExtResource("3_d2jt1")]([])

[sub_resource type="Resource" id="Resource_cgsrb"]
script = ExtResource("1_8ut2b")
title = "RejectPage"
description = "You reject the recruiter's request. He lets you move on but seems unhappy at the opportunity to lose such a promising soldier."
options = Array[ExtResource("3_d2jt1")]([])

