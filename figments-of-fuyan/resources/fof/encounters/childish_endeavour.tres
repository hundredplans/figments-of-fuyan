[sub_resource type="Resource" id="Resource_ejcsx"]
script = ExtResource("1_7bbi8")
title = "InformPage"
description = "The child is a known troublemaker and seemed to want to annoy his parents by dissapearing. They are thankful for your not leaving the village and wish you good luck on your journeys."
options = Array[ExtResource("3_8g4nq")]([])

