[sub_resource type="Resource" id="Resource_juoi7"]
script = ExtResource("1_7bbi8")
title = "StartPage"
description = "As you pass through a bustling palm town one of the headstrong village children follows you all the way to the village exit.  He seems reluctant to leave you but you feel you have a duty to take action."
